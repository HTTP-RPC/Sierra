<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE column-panel SYSTEM "sierra.dtd">

<column-panel padding="8" opaque="true">
    <form-panel>
        <spinner name="countSpinner" label="Quantity"/>

        <suggestion-picker name="sizeSuggestionPicker" label="&amp;Size" columns="10"/>
        <suggestion-picker name="colorSuggestionPicker" label="&amp;Color" columns="10" maximumRowCount="4"/>

        <spacer size="4"/>

        <button name="submitButton" text="Submit"/>
    </form-panel>

    <spacer weight="1"/>

    <label name="selectionLabel" horizontalAlignment="center"/>
</column-panel>

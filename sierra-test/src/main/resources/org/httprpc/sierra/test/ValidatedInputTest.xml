<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE column-panel SYSTEM "sierra.dtd">

<column-panel padding="8" opaque="true">
    <form-panel>
        <number-field name="numberField1" label="number1" columns="8"/>
        <number-field name="numberField2" label="number2" columns="8"/>

        <validated-text-field name="validatedTextField1" label="validatedText1" columns="8"/>
        <validated-text-field name="validatedTextField2" label="validatedText2" columns="8" pattern="validatedText2Pattern"/>

        <separator/>

        <button name="submitButton" text="submit"/>
    </form-panel>

    <spacer weight="1"/>

    <label name="messageLabel" horizontalAlignment="center"/>
</column-panel>

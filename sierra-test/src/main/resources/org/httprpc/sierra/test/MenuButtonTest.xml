<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE column-panel SYSTEM "sierra.dtd">

<column-panel spacing="8" padding="8" opaque="true">
    <row-panel spacing="8">
        <menu-button name="menuButton" text="showMenu">
            <menu-item name="menuItem1" text="item1"/>
            <menu-item name="menuItem2" text="item2"/>
            <menu-item name="menuItem3" text="item3"/>
        </menu-button>

        <check-box name="focusableCheckBox" text="focusable"/>
    </row-panel>

    <label name="selectionLabel"/>
</column-panel>

<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE column-panel SYSTEM "sierra.dtd">

<column-panel padding="8" opaque="true">
    <form-panel>
        <date-picker name="datePicker" label="date" columns="8"/>
        <time-picker name="timePicker" label="time" columns="8"/>

        <combo-box name="minuteIntervalComboBox" label="minuteInterval"/>

        <check-box name="strictCheckBox" text="strict"/>

        <separator/>

        <button name="submitButton" text="submit"/>
    </form-panel>

    <spacer weight="1"/>

    <label name="selectionLabel" horizontalAlignment="center"/>
</column-panel>

<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE row-panel SYSTEM "sierra.dtd">

<row-panel spacing="16" padding="16" opaque="true" background="white">
    <image-pane image="lighthouse.jpg"
        scaleMode="fill-height"
        cornerRadius="16"
        border="green, 2, solid, 16"/>

    <column-panel title="Title"
        titleColor="green"
        titleFont="h1.font"
        titleJustification="trailing"
        titlePosition="bottom"
        border="#ff0000, 1, dashed, 16"
        padding="16"
        weight="1">
        <label text="content" horizontalAlignment="center" border="#0000ff, 1, dotted, 16" weight="1"/>
    </column-panel>
</row-panel>
